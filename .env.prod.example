# ============================================================
# Ink Speaker 生产环境 .env 模板
# ============================================================
# 用法:
#   1. cp .env.prod.example .env.prod
#   2. 按需修改 .env.prod 中的值(尤其是 API_KEY / JWT_SECRET / JASYPT_KEY)
#   3. docker compose --env-file .env.prod up -d
#
# 重要:
#   - .env.prod 不要提交到 git(已在 .gitignore 中)
#   - 生产环境至少 32 字节的强随机密钥
# ============================================================

# ------------------------------------------------------------
# 1. 数据库
# ------------------------------------------------------------
DB_NAME=ink_speaker
DB_USERNAME=postgres
DB_PASSWORD=请替换为强密码_至少16字节

# ------------------------------------------------------------
# 2. Redis
# ------------------------------------------------------------
REDIS_PASSWORD=

# ------------------------------------------------------------
# 3. LLM API Key(必填)
# ------------------------------------------------------------
# DeepSeek / 通义千问 / Moonshot / 智谱 GLM 任选其一
OPENAI_API_KEY=sk-请替换为你的真实 API Key

# 模型配置(可选,留空走 application-prod.yml 默认)
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL_NAME=deepseek-v4-flash

# ------------------------------------------------------------
# 4. JWT 密钥(必填,生产至少 32 字节)
# ------------------------------------------------------------
# 生成命令: openssl rand -base64 48
JWT_SECRET=请替换为强随机字符串_至少32字节

# ------------------------------------------------------------
# 5. Jasypt 加密主密钥(必填)
# ------------------------------------------------------------
# 生成命令: openssl rand -base64 32
JASYPT_KEY=请替换为强随机字符串_至少32字节

# ------------------------------------------------------------
# 6. Profile(可选,默认 prod)
# ------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod

# ------------------------------------------------------------
# 7. 阿里云 ACR(容器镜像仓库,deploy.sh 用)
# ------------------------------------------------------------
# 控制台:https://cr.console.aliyun.com/
# 创建"个人实例"(免费)→ 命名空间 → 镜像仓库
# 设置"访问凭证"(固定密码)
ACR_REGISTRY=crpi-2t2oc7kie6ke8uce.cn-hangzhou.personal.cr.aliyuncs.com
ACR_NAMESPACE=mox-labb
ACR_USERNAME=请替换为你的阿里云账号
ACR_PASSWORD=请替换为ACR固定密码
