# ============================================================
# Novel Forge - 环境变量模板
# ============================================================
# 用法:
#   1. cp .env.example .env
#   2. 按需修改 .env 中的值(尤其是生产环境)
#   3. 启动 Spring Boot 时由启动脚本/IDE 注入这些环境变量
#
# 重要:
#   - .env 文件已被 .gitignore 忽略,不会提交
#   - 不要把真实密钥写入 .env.example
#   - 生产环境优先用 K8s Secret / Vault / CI Secret 注入
# ============================================================

# ------------------------------------------------------------
# 1. LLM API Key(必填)
# ------------------------------------------------------------
# OpenAI 兼容接口的 API Key
# DeepSeek:  https://platform.deepseek.com/api_keys
# 通义千问:   https://dashscope.console.aliyun.com
# Moonshot:  https://platform.moonshot.cn/console/api-keys
# 智谱 GLM:  https://open.bigmodel.cn/usercenter/apikeys
OPENAI_API_KEY=sk-your-api-key-here

# ------------------------------------------------------------
# 2. 数据库密码(必填)
# ------------------------------------------------------------
# PostgreSQL 密码,与 spring.datasource.password 对应
DB_PASSWORD=change-me-in-production

# ------------------------------------------------------------
# 3. Redis(生产必填,dev 可留空走默认 localhost:6379)
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------------------------------------------
# 4. JWT 密钥(必填,生产必须替换)
# ------------------------------------------------------------
# HS256 算法要求 secret 字节长度 >= 32
# 生成命令: openssl rand -base64 48
JWT_SECRET=please-replace-with-strong-random-secret-at-least-32-bytes

# ------------------------------------------------------------
# 5. Jasypt 加密主密钥(必填,生产必须从 K8s Secret 注入)
# ------------------------------------------------------------
# 用于解密 application.yml 中 ENC(...) 包裹的字段
# 生成命令: openssl rand -base64 32
JASYPT_KEY=novel-forge-dev-key

# ------------------------------------------------------------
# 6. 运行 Profile(可选)
# ------------------------------------------------------------
# 可选值: dev | prod(影响 application-{profile}.yml 加载)
SPRING_PROFILES_ACTIVE=dev

# ------------------------------------------------------------
# 7. 业务端口(可选,默认 9688)
# ------------------------------------------------------------
# SERVER_PORT=9688
# MANAGEMENT_SERVER_PORT=9689

# ============================================================
# 第 7 阶段:JVM 与 GC 参数(可选,详见 bin/start.sh)
# ============================================================
# 堆大小:容器化下用 RAM Percentage 让 JVM 自适应 cgroup
# JAVA_HEAP_INIT=-XX:InitialRAMPercentage=25
# JAVA_HEAP_MAX=-XX:MaxRAMPercentage=75

# GC 选择:G1GC(默认)/ ZGC(低延迟大堆)
# JAVA_GC=-XX:+UseG1GC
# JAVA_GC_OPTS=-XX:MaxGCPauseMillis=200 -XX:G1HeapRegionSize=4m -XX:InitiatingHeapOccupancyPercent=45

# 元空间上限
# JAVA_METASPACE=-XX:MetaspaceSize=256m -XX:MaxMetaspaceSize=512m

# GC 日志路径(dev 关闭,生产开启)
# JAVA_GC_LOG=-Xlog:gc*:file=logs/gc.log:time,uptime,level,tags:filecount=5,filesize=20m

# OOM 自动 dump
# JAVA_DIAGNOSTICS=-XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=logs/heapdump.hprof -XX:+ExitOnOutOfMemoryError

# 额外 JVM 参数(如远程调试 -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=5005)
# EXTRA_JVM_OPTS=

