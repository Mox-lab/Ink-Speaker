<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ink.speaker.novel.mapper.NovelCharacterMapper">

    <resultMap id="NovelCharacterMap" type="com.ink.speaker.novel.domain.entity.NovelCharacter">
        <id column="id" property="id"/>
        <result column="novel_id" property="novelId"/>
        <result column="name" property="name"/>
        <result column="age" property="age"/>
        <result column="gender" property="gender"/>
        <result column="personality" property="personality"/>
        <result column="weapon" property="weapon"/>
        <result column="background" property="background"/>
        <result column="identity" property="identity"/>
        <result column="appearance" property="appearance"/>
        <result column="relationships" property="relationships"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, novel_id, name, age, gender, personality, weapon, background,
        identity, appearance, relationships, created_at, updated_at
    </sql>

    <select id="findByNovelIdAndName" resultMap="NovelCharacterMap">
        SELECT <include refid="Base_Column_List"/>
        FROM novel_character
        WHERE novel_id = #{novelId}
          AND name = #{name}
        LIMIT 1
    </select>

    <select id="listByNovelId" resultMap="NovelCharacterMap">
        SELECT <include refid="Base_Column_List"/>
        FROM novel_character
        WHERE novel_id = #{novelId}
        ORDER BY id ASC
    </select>

    <select id="searchByNovelIdAndNameContaining" resultMap="NovelCharacterMap">
        SELECT <include refid="Base_Column_List"/>
        FROM novel_character
        WHERE novel_id = #{novelId}
          AND name ILIKE CONCAT('%', #{name}, '%')
        ORDER BY id ASC
    </select>

    <!-- 级联删除:删除指定小说的全部人物档案 -->
    <delete id="deleteByNovelId">
        DELETE FROM novel_character WHERE novel_id = #{novelId}
    </delete>

</mapper>
