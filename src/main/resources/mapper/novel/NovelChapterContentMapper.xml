<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ink.realm.novel.mapper.NovelChapterContentMapper">

    <!-- 级联删除:物理删除指定小说的全部章节(逻辑删除不适用级联清理,保留 XML) -->
    <delete id="deleteByNovelId">
        DELETE FROM novel_chapter_content WHERE novel_id = #{novelId}
    </delete>

    <!-- 物理清理同 (novel_id, chapter_no) 全部行(含逻辑删除残留),为新插入腾出唯一键 -->
    <delete id="physicallyDeleteByNovelIdAndChapterNo">
        DELETE FROM novel_chapter_content WHERE novel_id = #{novelId} AND chapter_no = #{chapterNo}
    </delete>

</mapper>
