<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ink.speaker.novel.mapper.NovelWorldSettingMapper">

    <resultMap id="NovelWorldSettingMap" type="com.ink.speaker.novel.domain.entity.NovelWorldSetting">
        <id column="id" property="id"/>
        <result column="novel_id" property="novelId"/>
        <result column="keyword" property="keyword"/>
        <result column="category" property="category"/>
        <result column="description" property="description"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, novel_id, keyword, category, description, created_at, updated_at
    </sql>

    <select id="findByNovelIdAndKeyword" resultMap="NovelWorldSettingMap">
        SELECT <include refid="Base_Column_List"/>
        FROM novel_world_setting
        WHERE novel_id = #{novelId}
          AND keyword = #{keyword}
        LIMIT 1
    </select>

    <select id="listByNovelId" resultMap="NovelWorldSettingMap">
        SELECT <include refid="Base_Column_List"/>
        FROM novel_world_setting
        WHERE novel_id = #{novelId}
        ORDER BY id ASC
    </select>

    <select id="listByNovelIdAndCategory" resultMap="NovelWorldSettingMap">
        SELECT <include refid="Base_Column_List"/>
        FROM novel_world_setting
        WHERE novel_id = #{novelId}
          AND category = #{category}
        ORDER BY id ASC
    </select>

    <select id="searchByNovelIdAndKeywordContaining" resultMap="NovelWorldSettingMap">
        SELECT <include refid="Base_Column_List"/>
        FROM novel_world_setting
        WHERE novel_id = #{novelId}
          AND keyword ILIKE CONCAT('%', #{keyword}, '%')
        ORDER BY id ASC
    </select>

</mapper>
