<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ink.realm.novel.mapper.NovelWorldSettingMapper">

    <!-- 级联删除:物理删除指定小说的全部世界观设定(保留 XML) -->
    <delete id="deleteByNovelId">
        DELETE FROM novel_world_setting WHERE novel_id = #{novelId}
    </delete>

    <!-- 物理清理同 (novel_id, keyword) 全部行(含逻辑删除残留),为新插入腾出唯一键 -->
    <delete id="physicallyDeleteByNovelIdAndKeyword">
        DELETE FROM novel_world_setting WHERE novel_id = #{novelId} AND keyword = #{keyword}
    </delete>

    <!-- 物理删除指定主键的设定行(用户主动删除单条,绕过逻辑删除拦截器释放唯一键) -->
    <delete id="physicallyDeleteById">
        DELETE FROM novel_world_setting WHERE id = #{id}
    </delete>

</mapper>
