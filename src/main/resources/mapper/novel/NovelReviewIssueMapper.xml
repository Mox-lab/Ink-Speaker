<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ink.speaker.novel.mapper.NovelReviewIssueMapper">

    <resultMap id="NovelReviewIssueMap" type="com.ink.speaker.novel.domain.entity.NovelReviewIssue">
        <id column="id" property="id"/>
        <result column="novel_id" property="novelId"/>
        <result column="chapter_no" property="chapterNo"/>
        <result column="severity" property="severity"/>
        <result column="category" property="category"/>
        <result column="location" property="location"/>
        <result column="description" property="description"/>
        <result column="suggestion" property="suggestion"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, novel_id, chapter_no, severity, category, location, description,
        suggestion, status, created_at, updated_at
    </sql>

    <select id="listByNovelIdAndChapterNoOrderBySeverityDesc"
            resultMap="NovelReviewIssueMap">
        SELECT <include refid="Base_Column_List"/>
        FROM novel_review_issue
        WHERE novel_id = #{novelId}
          AND chapter_no = #{chapterNo}
        ORDER BY severity DESC, id ASC
    </select>

    <select id="listByNovelIdAndStatusOrderByChapterNoAsc"
            resultMap="NovelReviewIssueMap">
        SELECT <include refid="Base_Column_List"/>
        FROM novel_review_issue
        WHERE novel_id = #{novelId}
          AND status = #{status}
        ORDER BY chapter_no ASC, id ASC
    </select>

    <select id="listByNovelIdAndStatus" resultMap="NovelReviewIssueMap">
        SELECT <include refid="Base_Column_List"/>
        FROM novel_review_issue
        WHERE novel_id = #{novelId}
          AND status = #{status}
        ORDER BY chapter_no ASC, id ASC
    </select>

    <!-- 级联删除:删除指定小说的全部审查问题 -->
    <delete id="deleteByNovelId">
        DELETE FROM novel_review_issue WHERE novel_id = #{novelId}
    </delete>

</mapper>
