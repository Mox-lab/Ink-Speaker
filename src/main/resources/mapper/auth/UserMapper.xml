<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ink.realm.auth.mapper.UserMapper">

    <resultMap id="RoleMap" type="ink.realm.auth.domain.entity.Role">
        <id column="r_id" property="id"/>
        <result column="r_name" property="name"/>
        <result column="r_ct_time" property="ctTime"/>
        <result column="r_ut_time" property="utTime"/>
    </resultMap>

    <resultMap id="UserMap" type="ink.realm.auth.domain.entity.User">
        <id column="u_id" property="id"/>
        <result column="u_username" property="username"/>
        <result column="u_nickname" property="nickname"/>
        <result column="u_password" property="password"/>
        <result column="u_enabled" property="enabled"/>
        <result column="u_ct_time" property="ctTime"/>
        <result column="u_ut_time" property="utTime"/>
        <collection property="roles" resultMap="RoleMap"/>
    </resultMap>

    <!-- 联表 fetch 角色:多表查询,保留 XML -->
    <select id="findByUsernameWithRoles" resultMap="UserMap">
        SELECT
            u.id           AS u_id,
            u.username     AS u_username,
            u.nickname     AS u_nickname,
            u.password     AS u_password,
            u.enabled      AS u_enabled,
            u.ct_time   AS u_ct_time,
            u.ut_time   AS u_ut_time,
            r.id           AS r_id,
            r.name         AS r_name,
            r.ct_time   AS r_ct_time,
            r.ut_time   AS r_ut_time
        FROM sys_users u
        LEFT JOIN sys_user_roles ur ON ur.user_id = u.id
        LEFT JOIN sys_roles r       ON r.id       = ur.role_id
        WHERE u.username = #{username}
          AND u.is_del = 0
    </select>

    <!-- 绑定默认角色:多表写入,保留 XML -->
    <insert id="bindDefaultUserRole">
        INSERT INTO sys_user_roles (user_id, role_id)
        SELECT #{userId}, r.id
        FROM sys_roles r
        WHERE r.name = 'ROLE_USER'
        ON CONFLICT DO NOTHING
    </insert>

    <!-- 批量列举用户角色名:单一 JOIN 聚合,供管理后台列表使用(避免 N+1) -->
    <resultMap id="UserRoleNameMap" type="ink.realm.auth.domain.vo.UserRoleName">
        <result column="user_id" property="userId"/>
        <result column="name" property="roleName"/>
    </resultMap>
    <select id="listUserRoleNames" resultMap="UserRoleNameMap">
        SELECT ur.user_id AS user_id, r.name AS name
          FROM sys_user_roles ur
          JOIN sys_roles r ON r.id = ur.role_id
         WHERE ur.user_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </select>

</mapper>
